{
  "name": "xgate",
  "version": "0.1.0",
  "description": "XGate - Quality Gate & AI Review for Every Commit",
  "type": "module",
  "engines": {
    "node": ">=18.x"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:mutation": "npx stryker run",
    "security:llm": "npx promptfoo eval --config promptfoo/promptsecurity.yaml",
    "build": "tsc",
    "lint": "eslint src --ext .ts",
    "principles": "npx tsx src/principles/index.ts"
  },
  "dependencies": {
    "@ast-grep/cli": "^0.36.2"
  },
  "devDependencies": {
    "@stryker-mutator/core": "^8.7.1",
    "@stryker-mutator/typescript-checker": "^8.7.1",
    "@stryker-mutator/vitest-runner": "^8.7.1",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitest/coverage-v8": "^1.6.1",
    "jscpd": "^4.0.9",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  },
  "keywords": [
    "clean-code",
    "solid",
    "principles",
    "code-quality",
    "ast-grep"
  ],
  "license": "MIT"
}
