{
  "evals": [
    {
      "id": 1,
      "name": "basic-trigger-check",
      "category": "trigger",
      "prompt": "Use the skill described in the SKILL.md",
      "assertions": [
        {"name": "skill-triggered", "type": "contains", "value": "skill", "weight": 3}
      ]
    },
    {
      "id": 2,
      "name": "normal-usage",
      "category": "normal",
      "prompt": "Perform the task defined in this skill",
      "assertions": [
        {"name": "task-completed", "type": "contains", "value": "done", "weight": 2}
      ]
    },
    {
      "id": 3,
      "name": "boundary-test",
      "category": "boundary",
      "prompt": "Try to use this skill with minimal input",
      "assertions": [
        {"name": "handles-minimal", "type": "contains", "value": "skill", "weight": 1}
      ]
    }
  ],
  "trigger_evals": {
    "should_trigger": ["use this skill", "apply this skill"],
    "should_not_trigger": ["ignore this", "do something else"]
  }
}
