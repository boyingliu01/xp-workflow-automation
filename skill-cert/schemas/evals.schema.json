{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EvalCase",
  "description": "A single evaluation test case",
  "type": "object",
  "required": ["id", "name", "category", "prompt", "assertions"],
  "properties": {
    "id": {"type": "integer"},
    "name": {"type": "string"},
    "category": {"type": "string", "enum": ["normal", "boundary", "failure", "trigger"]},
    "prompt": {"type": "string"},
    "expected_output": {"type": "string"},
    "files": {"type": "array", "items": {"type": "string"}},
    "assertions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type", "value"],
        "properties": {
          "name": {"type": "string"},
          "type": {"type": "string", "enum": ["contains", "not_contains", "regex", "starts_with", "json_valid"]},
          "value": {"type": "string"},
          "weight": {"type": "integer", "default": 1}
        }
      }
    }
  }
}
