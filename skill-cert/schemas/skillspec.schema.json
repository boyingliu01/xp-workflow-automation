{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SkillSpec",
  "description": "Structured semantic model extracted from SKILL.md",
  "type": "object",
  "required": ["name", "description", "workflow_steps"],
  "properties": {
    "name": {"type": "string"},
    "description": {"type": "string"},
    "triggers": {"type": "array", "items": {"type": "string"}},
    "workflow_steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type", "critical"],
        "properties": {
          "name": {"type": "string"},
          "type": {"type": "string"},
          "critical": {"type": "boolean"}
        }
      }
    },
    "anti_patterns": {"type": "array", "items": {"type": "string"}},
    "output_format": {"type": "array", "items": {"type": "string"}},
    "examples": {"type": "array", "items": {"type": "string"}},
    "content_length": {"type": "integer"},
    "parse_method": {"type": "string", "enum": ["regex", "llm", "hybrid"]},
    "parse_confidence": {"type": "number", "minimum": 0, "maximum": 1}
  }
}
