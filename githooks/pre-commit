#!/bin/bash
# OpenCode Quality Gates - Pre-Commit Hook
# 
# DESIGN PRINCIPLE: Zero tolerance - fail on missing capabilities
# If tool not available → BLOCK commit and notify user to fix environment
# User is responsible for ensuring environment is ready for AI automation.
#
# Blocks commits that fail quality gates

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "   QUALITY GATES - PRE-COMMIT CHECK"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# Get list of changed files
CHANGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$CHANGED_FILES" ]; then
  echo "No files changed. Skipping gates."
  exit 0
fi

# Determine project language stack
PROJECT_LANG=""
if [ -f "tsconfig.json" ] || [ -f "package.json" ]; then
  PROJECT_LANG="typescript"
elif [ -f "pyproject.toml" ] || [ -f "setup.py" ] || [ -f "requirements.txt" ]; then
  PROJECT_LANG="python"
elif [ -f "go.mod" ]; then
  PROJECT_LANG="go"
elif [ -f "pubspec.yaml" ]; then
  # Check if it's a Flutter project
  if grep -q "flutter:" pubspec.yaml 2>/dev/null || [ -f ".metadata" ]; then
    PROJECT_LANG="flutter"
  else
    PROJECT_LANG="dart"
  fi
fi

# Check if this is a documentation-only project (no source code)
# Such projects have only markdown, yaml, json, skills, docs - no actual code
if [ -z "$PROJECT_LANG" ]; then
  # Count source code files (including shell scripts)
  CODE_FILES=$(find . -type f \( -name "*.py" -o -name "*.js" -o -name "*.ts" -o -name "*.tsx" -o -name "*.java" -o -name "*.go" -o -name "*.rs" -o -name "*.cpp" -o -name "*.c" -o -name "*.swift" -o -name "*.kt" -o -name "*.sh" -o -name "*.dart" \) -not -path "./.git/*" 2>/dev/null | wc -l)
  
  if [ "$CODE_FILES" -eq 0 ]; then
    PROJECT_LANG="documentation-only"
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "   📚 DOCUMENTATION-ONLY PROJECT DETECTED"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "This project contains no source code files."
    echo "Skipping static analysis and test gates."
    echo ""
    echo "Proceeding with documentation-only checks..."
  fi
fi

# ============================================================================
# Gate 1: Static Analysis (MANDATORY - fail if tool not available)
# ============================================================================
echo ""
echo "→ Gate 1: Static analysis..."

if [ "$PROJECT_LANG" = "documentation-only" ]; then
  # Documentation-only project - skip static analysis
  echo "✅ Skipped (no source code to analyze)."
  
elif [ "$PROJECT_LANG" = "typescript" ]; then
  # TypeScript: require tsc + ESLint
  if ! command -v tsc &> /dev/null; then
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "   ❌ ENVIRONMENT ERROR - COMMIT BLOCKED"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "Required tool 'tsc' (TypeScript compiler) is NOT installed."
    echo ""
    echo "Your responsibility: Install the tool to enable quality gates."
    echo ""
    echo "Install commands:"
    echo "  npm install -D typescript"
    echo "  or: yarn add -D typescript"
    echo ""
    echo "After installation, retry the commit."
    echo ""
    exit 1
  fi
  
  if ! command -v eslint &> /dev/null && ! command -v npx &> /dev/null; then
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "   ❌ ENVIRONMENT ERROR - COMMIT BLOCKED"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "Required tool 'eslint' is NOT installed."
    echo ""
    echo "Install commands:"
    echo "  npm install -D eslint"
    echo "  or use npx: npx eslint (will auto-install)"
    echo ""
    exit 1
  fi
  
  # Run TypeScript check
  npx tsc --noEmit 2>&1 | head -30
  TSC_EXIT=$?
  if [ "$TSC_EXIT" -ne 0 ]; then
    echo ""
    echo "❌ TYPE ERRORS. Commit blocked."
    echo "Fix the type errors above before committing."
    exit 1
  fi
  echo "✅ TypeScript check passed."
  
  # Run ESLint
  if [ -f ".eslintrc.json" ] || [ -f ".eslintrc.js" ] || [ -f "eslint.config.js" ]; then
    npx eslint "$CHANGED_FILES" --max-warnings=0 2>&1 | head -30
    ESLINT_EXIT=$?
    if [ "$ESLINT_EXIT" -ne 0 ]; then
      echo ""
      echo "❌ LINT ERRORS. Commit blocked."
      echo "Fix the lint errors above before committing."
      exit 1
    fi
    echo "✅ ESLint passed."
  fi

elif [ "$PROJECT_LANG" = "python" ]; then
  # Python: require Ruff (100x faster than Flake8) + optional mypy for type check
  if ! command -v ruff &> /dev/null; then
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "   ❌ ENVIRONMENT ERROR - COMMIT BLOCKED"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "Required tool 'ruff' is NOT installed."
    echo ""
    echo "Ruff is the fastest Python linter (100x faster than Flake8)."
    echo "It covers: syntax, complexity, duplicate code, style, imports."
    echo ""
    echo "Install commands:"
    echo "  pip install ruff"
    echo "  or: pipx install ruff"
    echo "  or: conda install -c conda-forge ruff"
    echo ""
    echo "After installation, retry the commit."
    echo ""
    exit 1
  fi
  
  # Run Ruff (includes syntax, lint, complexity checks)
  ruff check "$CHANGED_FILES" 2>&1 | head -30
  RUFF_EXIT=$?
  if [ "$RUFF_EXIT" -ne 0 ]; then
    echo ""
    echo "❌ RUFF ERRORS. Commit blocked."
    echo "Fix the lint errors above before committing."
    echo ""
    echo "Tip: Run 'ruff check --fix' to auto-fix some issues."
    exit 1
  fi
  echo "✅ Ruff lint check passed."
  
  # Optional: Type checking with mypy (if installed)
  if command -v mypy &> /dev/null; then
    mypy "$CHANGED_FILES" --ignore-missing-imports 2>&1 | head -30
    MYPY_EXIT=$?
    if [ "$MYPY_EXIT" -ne 0 ]; then
      echo ""
      echo "❌ TYPE ERRORS (mypy). Commit blocked."
      echo "Fix the type errors above before committing."
      exit 1
    fi
    echo "✅ mypy type check passed."
  fi

elif [ "$PROJECT_LANG" = "go" ]; then
  # Go: require golangci-lint
  if ! command -v golangci-lint &> /dev/null; then
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "   ❌ ENVIRONMENT ERROR - COMMIT BLOCKED"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "Required tool 'golangci-lint' is NOT installed."
    echo ""
    echo "golangci-lint is the fastest Go linter aggregator."
    echo "It includes: gofmt, govet, ineffassign, staticcheck, and more."
    echo ""
    echo "Install commands:"
    echo "  go install github.com/golangci/golangci-lint/cmd/golangci-lint@latest"
    echo "  or: curl -sSfL https://raw.githubusercontent.com/golangci/golangci-lint/master/install.sh | sh"
    echo ""
    exit 1
  fi
  
  golangci-lint run 2>&1 | head -30
  GO_LINT_EXIT=$?
  if [ "$GO_LINT_EXIT" -ne 0 ]; then
    echo ""
    echo "❌ LINT ERRORS (golangci-lint). Commit blocked."
    echo "Fix the lint errors above before committing."
    exit 1
  fi
  echo "✅ golangci-lint passed."

elif [ "$PROJECT_LANG" = "dart" ]; then
  # Dart: require dart analyze
  if ! command -v dart &> /dev/null; then
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "   ❌ ENVIRONMENT ERROR - COMMIT BLOCKED"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "Required tool 'dart' SDK is NOT installed."
    echo ""
    echo "Install commands:"
    echo "  macOS: brew install dart"
    echo "  Linux: sudo apt-get install dart"
    echo "  Windows: choco install dart-sdk"
    echo "  or: https://dart.dev/get-dart"
    echo ""
    exit 1
  fi
  
  dart analyze 2>&1 | head -30
  DART_ANALYZE_EXIT=$?
  if [ "$DART_ANALYZE_EXIT" -ne 0 ]; then
    echo ""
    echo "❌ DART ANALYZE ERRORS. Commit blocked."
    echo "Fix the analysis errors above before committing."
    exit 1
  fi
  echo "✅ dart analyze passed."

elif [ "$PROJECT_LANG" = "flutter" ]; then
  # Flutter: require flutter analyze
  if ! command -v flutter &> /dev/null; then
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "   ❌ ENVIRONMENT ERROR - COMMIT BLOCKED"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "Required tool 'flutter' SDK is NOT installed."
    echo ""
    echo "Install commands:"
    echo "  https://docs.flutter.dev/get-started/install"
    echo ""
    exit 1
  fi
  
  flutter analyze 2>&1 | head -30
  FLUTTER_ANALYZE_EXIT=$?
  if [ "$FLUTTER_ANALYZE_EXIT" -ne 0 ]; then
    echo ""
    echo "❌ FLUTTER ANALYZE ERRORS. Commit blocked."
    echo "Fix the analysis errors above before committing."
    exit 1
  fi
  echo "✅ flutter analyze passed."

else
  # Unknown project type - MUST FAIL
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "   ❌ ENVIRONMENT ERROR - COMMIT BLOCKED"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
  echo "Cannot determine project language stack."
  echo ""
  echo "Detected files: tsconfig.json, package.json, pyproject.toml, go.mod, pubspec.yaml"
  echo "None of these found in current directory."
  echo ""
  echo "Your responsibility:"
  echo "  1. Ensure you are in the correct project directory"
  echo "  2. Or add a .pre-commit-config.yaml for custom configuration"
  echo ""
  exit 1
fi

# ============================================================================
# Gate 2: Linting (MANDATORY for TypeScript/Python - already done in Gate 1)
# ============================================================================
echo ""
echo "→ Gate 2: Additional linting..."

# For TypeScript/Python/Dart/Flutter, Gate 1 already covered lint via tsc/ESLint/Ruff/dart analyze/flutter analyze
# This gate runs additional project-specific lint if configured

if [ "$PROJECT_LANG" = "typescript" ] || [ "$PROJECT_LANG" = "python" ] || [ "$PROJECT_LANG" = "dart" ] || [ "$PROJECT_LANG" = "flutter" ]; then
  # Already linted in Gate 1 - this is optional additional lint
  if [ -f ".pre-commit-config.yaml" ] && command -v pre-commit &> /dev/null; then
    pre-commit run --files "$CHANGED_FILES" 2>&1
    if [ $? -ne 0 ]; then
      echo "❌ PRE-COMMIT FAILED. Commit blocked."
      exit 1
    fi
    echo "✅ pre-commit hooks passed."
  fi
  
elif [ "$PROJECT_LANG" = "go" ]; then
  # Go already linted in Gate 1 via golangci-lint
  echo "✅ Linting already completed in Gate 1 (golangci-lint)."
elif [ "$PROJECT_LANG" = "documentation-only" ]; then
  echo "✅ Skipped (no source code to lint)."
fi

# ============================================================================
# Gate 3: Unit Tests (MANDATORY - fail if test framework not configured)
# ============================================================================
echo ""
echo "→ Gate 3: Unit tests..."

HAS_TEST_CONFIG=false

if [ "$PROJECT_LANG" = "typescript" ]; then
  # TypeScript: require test script in package.json
  if [ -f "package.json" ]; then
    if grep -q "\"test\"" package.json; then
      HAS_TEST_CONFIG=true
      npm test -- --bail --reporters=min 2>&1 | tail -30
      TEST_EXIT=$?
      if [ "$TEST_EXIT" -ne 0 ]; then
        echo ""
        echo "❌ TESTS FAILED. Commit blocked."
        echo "Fix failing tests before committing."
        exit 1
      fi
      echo "✅ Tests passed."
    fi
  fi

elif [ "$PROJECT_LANG" = "python" ]; then
  # Python: require pytest configuration
  if [ -f "pytest.ini" ] || [ -f "pyproject.toml" ] || [ -f "setup.cfg" ]; then
    if grep -q "pytest" pyproject.toml 2>/dev/null || [ -f "pytest.ini" ] || grep -q "\[tool:pytest\]" setup.cfg 2>/dev/null; then
      HAS_TEST_CONFIG=true
      if ! command -v pytest &> /dev/null; then
        echo ""
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo "   ❌ ENVIRONMENT ERROR - COMMIT BLOCKED"
        echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
        echo ""
        echo "pytest configuration found but 'pytest' is NOT installed."
        echo ""
        echo "Install commands:"
        echo "  pip install pytest"
        echo "  or: pip install pytest pytest-cov"
        echo ""
        exit 1
      fi
      pytest --tb=short -q 2>&1 | tail -30
      TEST_EXIT=$?
      if [ "$TEST_EXIT" -ne 0 ]; then
        echo ""
        echo "❌ PYTEST FAILED. Commit blocked."
        echo "Fix failing tests before committing."
        exit 1
      fi
      echo "✅ pytest passed."
    fi
  fi

elif [ "$PROJECT_LANG" = "go" ]; then
  # Go: require go test
  HAS_TEST_CONFIG=true
  go test ./... 2>&1 | tail -30
  TEST_EXIT=$?
  if [ "$TEST_EXIT" -ne 0 ]; then
    echo ""
    echo "❌ GO TESTS FAILED. Commit blocked."
    echo "Fix failing tests before committing."
    exit 1
  fi
  echo "✅ Go tests passed."

elif [ "$PROJECT_LANG" = "dart" ]; then
  # Dart: require dart test configuration
  if [ -f "pubspec.yaml" ]; then
    HAS_TEST_CONFIG=true
    if ! command -v dart &> /dev/null; then
      echo ""
      echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
      echo "   ❌ ENVIRONMENT ERROR - COMMIT BLOCKED"
      echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
      echo ""
      echo "Required tool 'dart' is NOT installed."
      echo ""
      echo "Install commands:"
      echo "  macOS: brew install dart"
      echo "  Linux: sudo apt-get install dart"
      echo ""
      exit 1
    fi
    dart test 2>&1 | tail -30
    TEST_EXIT=$?
    if [ "$TEST_EXIT" -ne 0 ]; then
      echo ""
      echo "❌ DART TEST FAILED. Commit blocked."
      echo "Fix failing tests before committing."
      exit 1
    fi
    echo "✅ dart test passed."
  fi

elif [ "$PROJECT_LANG" = "flutter" ]; then
  # Flutter: require flutter test
  if [ -f "pubspec.yaml" ]; then
    HAS_TEST_CONFIG=true
    if ! command -v flutter &> /dev/null; then
      echo ""
      echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
      echo "   ❌ ENVIRONMENT ERROR - COMMIT BLOCKED"
      echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
      echo ""
      echo "Required tool 'flutter' is NOT installed."
      echo ""
      echo "Install commands:"
      echo "  https://docs.flutter.dev/get-started/install"
      echo ""
      exit 1
    fi
    flutter test 2>&1 | tail -30
    TEST_EXIT=$?
    if [ "$TEST_EXIT" -ne 0 ]; then
      echo ""
      echo "❌ FLUTTER TEST FAILED. Commit blocked."
      echo "Fix failing tests before committing."
      exit 1
    fi
    echo "✅ flutter test passed."
  fi

elif [ "$PROJECT_LANG" = "documentation-only" ]; then
  # Documentation-only project - no tests required
  HAS_TEST_CONFIG=true
  echo "✅ Skipped (no source code to test)."
fi

# Check if test configuration was found
# Skip this check for documentation-only projects
if [ "$HAS_TEST_CONFIG" = "false" ] && [ "$PROJECT_LANG" != "documentation-only" ]; then
  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "   ❌ ENVIRONMENT ERROR - COMMIT BLOCKED"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""
  echo "No test configuration found for project type: $PROJECT_LANG"
  echo ""
  echo "Tests are MANDATORY for quality gates."
  echo ""
  echo "Your responsibility:"
  if [ "$PROJECT_LANG" = "typescript" ]; then
    echo "  1. Add 'test' script to package.json"
    echo "     Example: \"test\": \"jest\" or \"test\": \"vitest\""
    echo ""
    echo "  Install test framework:"
    echo "     npm install -D jest"
    echo "     or: npm install -D vitest"
  elif [ "$PROJECT_LANG" = "python" ]; then
    echo "  1. Add pytest configuration to pyproject.toml"
    echo "     Example: [tool.pytest.ini_options]"
    echo ""
    echo "  Install pytest:"
    echo "     pip install pytest"
  elif [ "$PROJECT_LANG" = "dart" ]; then
    echo "  1. Add test dependencies to pubspec.yaml"
    echo "     Example: dev_dependencies:"
    echo "       test: ^1.0.0"
    echo ""
    echo "  Install test framework:"
    echo "     dart pub get"
  elif [ "$PROJECT_LANG" = "flutter" ]; then
    echo "  1. Add test dependencies to pubspec.yaml"
    echo "     Example: dev_dependencies:"
    echo "       flutter_test: sdk: flutter"
    echo ""
    echo "  Install test framework:"
    echo "     flutter pub get"
  fi
  echo ""
  echo "After adding test configuration, retry the commit."
  echo ""
  exit 1
fi

# ============================================================================
# Gate 4: Coverage (MANDATORY - fail if coverage tool not available)
# ============================================================================
echo ""
echo "→ Gate 4: Coverage check..."

if [ "$PROJECT_LANG" = "typescript" ]; then
  if [ -f "package.json" ] && grep -q "\"test:coverage\"" package.json; then
