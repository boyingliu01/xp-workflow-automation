        echo "❌ COVERAGE FAILED. Commit blocked."
        exit 1
      fi
      echo "✅ Coverage check passed."
    else
      echo ""
      echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
