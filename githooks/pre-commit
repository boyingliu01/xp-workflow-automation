# Gate 8: Boy Scout Rule (MANDATORY for legacy projects)
# ============================================================================
echo ""
echo "→ Gate 8: Boy Scout Rule enforcement..."

if [ "$PROJECT_LANG" != "documentation-only" ]; then
  # Check if baseline file exists
  if [ ! -f ".warnings-baseline.json" ]; then
    echo "ℹ️  No baseline file found (.warnings-baseline.json)."
    echo "   Boy Scout Rule is optional for new projects."
    echo "   To enable: Run 'npx tsx src/principles/boy-scout.ts --init-baseline'"
    echo "✅ Boy Scout Rule skipped (no baseline)."
  else
    # Check boy-scout.ts CLI availability
    if [ -f "src/principles/boy-scout.ts" ]; then
      # Separate new files and modified files from git diff
      NEW_FILES=$(git diff --cached --name-only --diff-filter=A | tr '\n' ',' | sed 's/,$//')
      MODIFIED_FILES=$(git diff --cached --name-only --diff-filter=M | tr '\n' ',' | sed 's/,$//')
      
      if [ -z "$NEW_FILES" ] && [ -z "$MODIFIED_FILES" ]; then
        echo "✅ No new or modified files to check (Boy Scout Rule)."
      else
        echo "Running Boy Scout Rule enforcement..."
        
        # Run boy-scout CLI
        BOY_SCOUT_OUTPUT=$(npx tsx src/principles/boy-scout.ts \
          --new-files "$NEW_FILES" \
          --modified-files "$MODIFIED_FILES" \
          --baseline ".warnings-baseline.json" \
          2>&1)
        
        BOY_SCOUT_EXIT=$?
        
        if [ "$BOY_SCOUT_EXIT" -ne 0 ]; then
          echo ""
          echo "$BOY_SCOUT_OUTPUT"
          echo ""
          echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
          echo "   ❌ BOY SCOUT RULE VIOLATION - COMMIT BLOCKED"
          echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
          echo ""
          echo "Boy Scout Rule: Leave the code cleaner than you found it."
          echo ""
          echo "Requirements:"
          echo "  - NEW files must have zero warnings"
          echo "  - MODIFIED files cannot increase warnings"
          echo "  - Files with <=5 warnings must clear to zero"
          echo ""
          echo "Fix the violations above or update the baseline:"
          echo "  npx tsx src/principles/boy-scout.ts --init-baseline"
          echo ""
          exit 1
        fi
        
        # Check for violations in output
        VIOLATION_COUNT=$(echo "$BOY_SCOUT_OUTPUT" | grep -c '"enforcement": "BLOCK"' || echo "0")
        
        if [ "$VIOLATION_COUNT" -gt 0 ]; then
          echo ""
          echo "$BOY_SCOUT_OUTPUT"
          echo ""
          echo "❌ Boy Scout Rule violations detected."
          echo "Fix the warnings before committing."
          exit 1
        fi
        
        echo "✅ Boy Scout Rule passed."
      fi
    else
      echo "ℹ️  boy-scout.ts CLI not found. Skipping Boy Scout Rule."
      echo "   Expected: src/principles/boy-scout.ts"
    fi
  fi
else
  echo "✅ Skipped (documentation-only project)."
fi

