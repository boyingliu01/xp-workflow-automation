echo ""
echo "→ Gate 7: Cyclomatic complexity check (threshold: 5)..."

if [ "$PROJECT_LANG" != "documentation-only" ]; then
  CCN_THRESHOLD=5
  CCN_ERROR_THRESHOLD=10
  
  # Check lizard availability
  if ! command -v lizard > /dev/null 2>&1; then
    if [ -f ~/.local/bin/lizard ]; then
      LIZARD_CMD=~/.local/bin/lizard
    else
      echo ""
      echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
