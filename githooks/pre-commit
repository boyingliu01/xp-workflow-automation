      echo ""
      echo "Required tool 'lizard' is NOT installed."
      echo "lizard provides function-level cyclomatic complexity analysis."
      echo ""
      echo "Install command:"
      echo "  pip3 install --user lizard"
      echo ""
      echo "After installation, retry the commit."
      echo ""
      exit 1
    fi
  else
    LIZARD_CMD=lizard
  fi
  
  # Get changed source files for complexity check
  CC_FILES=$(echo "$CHANGED_FILES" | grep -E '\.(ts|tsx|js|jsx|py|go|java|swift|cpp|c|m|mm)$' || true)
  
  if [ -n "$CC_FILES" ]; then
    echo "Checking complexity for: $CC_FILES"
    
    # Run lizard with CCN threshold only (lizard has no -w parameter)
    # Valid params: -C CCN (complexity), -L LENGTH (function length)
    CC_OUTPUT=$($LIZARD_CMD -C $CCN_THRESHOLD $CC_FILES 2>&1)
    CC_EXIT=$?
    
    # If lizard command failed (wrong params or tool error), block commit
    if [ "$CC_EXIT" -ne 0 ]; then
      echo ""
      echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
      echo "   ❌ LIZARD COMMAND FAILED - COMMIT BLOCKED"
      echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
      echo ""
      echo "lizard command execution failed with exit code $CC_EXIT"
      echo ""
      echo "Output:"
      echo "$CC_OUTPUT"
      echo ""
      echo "This is a critical bug - complexity check must not be skipped."
      echo "Ensure lizard is correctly installed and invoked."
      echo ""
      exit 1
    fi
    
    # Count warnings (CCN > threshold)
    CC_WARNINGS=$(echo "$CC_OUTPUT" | grep -c "warning:" || echo "0")
    CC_ERRORS=$(echo "$CC_OUTPUT" | grep -E "CCN [0-9]+" | awk '{if($3 > 10) print}' | wc -l || echo "0")
    
    if [ "$CC_ERRORS" -gt 0 ]; then
      echo ""
      echo "$CC_OUTPUT"
      echo ""
      echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
      echo "   ❌ COMPLEXITY VIOLATIONS - COMMIT BLOCKED"
      echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
      echo ""
      echo "Found $CC_ERRORS functions with CCN > $CCN_ERROR_THRESHOLD."
      echo "These functions are too complex and must be refactored."
      echo ""
      exit 1
    fi
    
    if [ "$CC_WARNINGS" -gt 0 ]; then
      echo ""
      echo "$CC_OUTPUT"
      echo ""
      echo "⚠️  WARNING: $CC_WARNINGS functions have CCN > $CCN_THRESHOLD."
      echo "Consider refactoring for better maintainability."
      echo "✅ Complexity check passed (warnings allowed)."
    else
