#!/bin/bash
# OpenCode Quality Gates - Pre-Commit Hook
# 
# DESIGN PRINCIPLE: Zero tolerance - fail on missing capabilities
# If tool not available → BLOCK commit and notify user to fix environment
# User is responsible for ensuring environment is ready for AI automation.
#
# Blocks commits that fail quality gates

# ============================================================================
# Helper Functions
# ============================================================================

# Parse LCOV file and return coverage percentage
# Usage: parse_lcov_coverage <lcov_file>
# Returns: coverage percentage (e.g., "85.5")
parse_lcov_coverage() {
  local lcov_file="$1"
  local total_lines=0
  local covered_lines=0
  
  if [ ! -f "$lcov_file" ]; then
    echo "0"
    return
  fi
  
  # Extract LF (Lines Found) and LH (Lines Hit) from lcov.info
  while IFS= read -r line; do
    case "$line" in
      LF:*)
        total_lines=$(echo "$line" | sed 's/LF://')
        ;;
      LH:*)
        covered_lines=$(echo "$line" | sed 's/LH://')
        ;;
    esac
  done < "$lcov_file"
  
  if [ "$total_lines" -gt 0 ]; then
    # Calculate percentage using awk for floating point
    awk "BEGIN {printf \"%.1f\", ($covered_lines / $total_lines) * 100}"
  else
    echo "0"
  fi
}

# Run command in subdirectory if PROJECT_SUBDIR is set
# Usage: run_in_subdir <command>
run_in_subdir() {
  local cmd="$1"
  
  if [ -n "$PROJECT_SUBDIR" ] && [ "$PROJECT_SUBDIR" != "." ]; then
    # Run command in subdirectory, then return to original directory
    pushd "$PROJECT_SUBDIR" > /dev/null 2>&1
    eval "$cmd"
    local exit_code=$?
    popd > /dev/null 2>&1
    return $exit_code
  else
    # Run in current directory
    eval "$cmd"
    return $?
  fi
}

# Check if file exists in subdirectory
# Usage: file_exists_in_subdir <filename>
file_exists_in_subdir() {
  local filename="$1"
  
  if [ -n "$PROJECT_SUBDIR" ] && [ "$PROJECT_SUBDIR" != "." ]; then
    [ -f "$PROJECT_SUBDIR/$filename" ]
  else
    [ -f "$filename" ]
  fi
}

echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "   QUALITY GATES - PRE-COMMIT CHECK"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# Get list of changed files
CHANGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$CHANGED_FILES" ]; then
  echo "No files changed. Skipping gates."
  exit 0
fi

# Determine project language stack
PROJECT_LANG=""
if [ -f "tsconfig.json" ] || [ -f "package.json" ]; then
  PROJECT_LANG="typescript"
elif [ -f "pyproject.toml" ] || [ -f "setup.py" ] || [ -f "requirements.txt" ]; then
  PROJECT_LANG="python"
elif [ -f "go.mod" ]; then
  PROJECT_LANG="go"
elif [ -f "pubspec.yaml" ]; then
  # Check if it's a Flutter project
  if grep -q "flutter:" pubspec.yaml 2>/dev/null || [ -f ".metadata" ]; then
    PROJECT_LANG="flutter"
  else
    PROJECT_LANG="dart"
  fi
elif [ -f "CMakeLists.txt" ] || [ -f "Makefile" ]; then
  CPP_FILES=$(find . -maxdepth 2 -name "*.cpp" -o -name "*.cxx" -o -name "*.cc" -not -path "./.git/*" 2>/dev/null | head -1)
  OBJC_FILES=$(find . -maxdepth 2 -name "*.m" -o -name "*.mm" -not -path "./.git/*" 2>/dev/null | head -1)
  if [ -n "$CPP_FILES" ]; then
    PROJECT_LANG="cpp"
  elif [ -n "$OBJC_FILES" ]; then
    PROJECT_LANG="objectivec"
  fi
elif [ -f "*.xcodeproj" ] || [ -d "*.xcworkspace" ]; then
  # Xcode project - Objective-C or Swift
  OBJC_FILES=$(find . -maxdepth 2 -name "*.m" -o -name "*.mm" -not -path "./.git/*" 2>/dev/null | head -1)
  if [ -n "$OBJC_FILES" ]; then
    PROJECT_LANG="objectivec"
  fi
elif [ -f "pom.xml" ] || [ -f "build.gradle" ] || [ -f "build.gradle.kts" ]; then
  # Check if it's Kotlin or Java
  KOTLIN_FILES=$(find . -name "*.kt" -not -path "./.git/*" 2>/dev/null | wc -l)
  if [ "$KOTLIN_FILES" -gt 0 ]; then
    PROJECT_LANG="kotlin"
  else
    PROJECT_LANG="java"
  fi
fi

# If not found at root, search subdirectories (max depth 2) for project manifests
# This supports mixed/hybrid project structures like:
#   root: Documentation + scripts
#   subdirectory: Flutter/TypeScript/Python/Go project
PROJECT_SUBDIR=""
if [ -z "$PROJECT_LANG" ]; then
  # Search for TypeScript/JavaScript projects
  TSCONFIG_SUB=$(find . -maxdepth 2 -name "tsconfig.json" -not -path "./.git/*" -not -path "./node_modules/*" 2>/dev/null | head -1)
  if [ -n "$TSCONFIG_SUB" ]; then
    PROJECT_LANG="typescript"
    PROJECT_SUBDIR=$(dirname "$TSCONFIG_SUB")
  fi
  
  # Search for Python projects
  if [ -z "$PROJECT_LANG" ]; then
    PYPROJECT_SUB=$(find . -maxdepth 2 -name "pyproject.toml" -not -path "./.git/*" 2>/dev/null | head -1)
    if [ -n "$PYPROJECT_SUB" ]; then
      PROJECT_LANG="python"
      PROJECT_SUBDIR=$(dirname "$PYPROJECT_SUB")
    fi
  fi
  
  # Search for Go projects
  if [ -z "$PROJECT_LANG" ]; then
    GOMOD_SUB=$(find . -maxdepth 2 -name "go.mod" -not -path "./.git/*" 2>/dev/null | head -1)
    if [ -n "$GOMOD_SUB" ]; then
      PROJECT_LANG="go"
      PROJECT_SUBDIR=$(dirname "$GOMOD_SUB")
    fi
  fi
  
  # Search for Flutter/Dart projects
  if [ -z "$PROJECT_LANG" ]; then
    PUBSPEC_SUB=$(find . -maxdepth 2 -name "pubspec.yaml" -not -path "./.git/*" 2>/dev/null | head -1)
    if [ -n "$PUBSPEC_SUB" ]; then
      if grep -q "flutter:" "$PUBSPEC_SUB" 2>/dev/null || [ -f "$(dirname "$PUBSPEC_SUB")/.metadata" ]; then
        PROJECT_LANG="flutter"
      else
        PROJECT_LANG="dart"
      fi
      PROJECT_SUBDIR=$(dirname "$PUBSPEC_SUB")
    fi
  fi
  
  # Search for Java/Kotlin projects
  if [ -z "$PROJECT_LANG" ]; then
    POM_SUB=$(find . -maxdepth 2 -name "pom.xml" -not -path "./.git/*" 2>/dev/null | head -1)
    GRADLE_SUB=$(find . -maxdepth 2 -name "build.gradle" -not -path "./.git/*" 2>/dev/null | head -1)
    if [ -n "$POM_SUB" ] || [ -n "$GRADLE_SUB" ]; then
      MANIFEST_FILE="${POM_SUB:-$GRADLE_SUB}"
      PROJECT_SUBDIR=$(dirname "$MANIFEST_FILE")
      # Check for Kotlin files in subdirectory
      KOTLIN_COUNT=$(find "$PROJECT_SUBDIR" -name "*.kt" -not -path "*/.git/*" 2>/dev/null | wc -l)
      if [ "$KOTLIN_COUNT" -gt 0 ]; then
        PROJECT_LANG="kotlin"
      else
        PROJECT_LANG="java"
      fi
    fi
  fi
  
  # Search for C++ projects
  if [ -z "$PROJECT_LANG" ]; then
    CMAKE_SUB=$(find . -maxdepth 2 -name "CMakeLists.txt" -not -path "./.git/*" 2>/dev/null | head -1)
    if [ -n "$CMAKE_SUB" ]; then
      PROJECT_LANG="cpp"
      PROJECT_SUBDIR=$(dirname "$CMAKE_SUB")
    fi
  fi
  
  # Report detected subdirectory project
  if [ -n "$PROJECT_SUBDIR" ] && [ -n "$PROJECT_LANG" ]; then
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "   📁 SUBDIRECTORY PROJECT DETECTED"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "Language: $PROJECT_LANG"
    echo "Location: $PROJECT_SUBDIR/"
    echo ""
  fi
fi

# Check if this is a documentation-only project (no source code)
# Such projects have only markdown, yaml, json, skills, docs - no actual code
if [ -z "$PROJECT_LANG" ]; then
  # Count source code files (including shell scripts)
  CODE_FILES=$(find . -type f \( -name "*.py" -o -name "*.js" -o -name "*.ts" -o -name "*.tsx" -o -name "*.java" -o -name "*.go" -o -name "*.rs" -o -name "*.cpp" -o -name "*.c" -o -name "*.swift" -o -name "*.kt" -o -name "*.sh" -o -name "*.dart" \) -not -path "./.git/*" 2>/dev/null | wc -l)
  
  if [ "$CODE_FILES" -eq 0 ]; then
    PROJECT_LANG="documentation-only"
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "   📚 DOCUMENTATION-ONLY PROJECT DETECTED"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "This project contains no source code files."
    echo "Skipping static analysis and test gates."
    echo ""
    echo "Proceeding with documentation-only checks..."
  fi
fi

# Switch to subdirectory if detected (for mixed/hybrid projects)
# All subsequent gates will run in the subdirectory context
ORIGINAL_DIR=""
if [ -n "$PROJECT_SUBDIR" ] && [ "$PROJECT_SUBDIR" != "." ] && [ "$PROJECT_LANG" != "documentation-only" ]; then
  ORIGINAL_DIR=$(pwd)
  cd "$PROJECT_SUBDIR"
  echo "Working in: $PROJECT_SUBDIR/"
  echo ""
fi

# ============================================================================
# Gate 1: Static Analysis (MANDATORY - fail if tool not available)
# ============================================================================
echo ""
echo "→ Gate 1: Static analysis..."

if [ "$PROJECT_LANG" = "documentation-only" ]; then
  # Documentation-only project - skip static analysis
  echo "✅ Skipped (no source code to analyze)."
  
elif [ "$PROJECT_LANG" = "typescript" ]; then
  # TypeScript: require tsc + ESLint
  if ! command -v tsc &> /dev/null; then
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "   ❌ ENVIRONMENT ERROR - COMMIT BLOCKED"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "Required tool 'tsc' (TypeScript compiler) is NOT installed."
    echo ""
    echo "Your responsibility: Install the tool to enable quality gates."
    echo ""
    echo "Install commands:"
    echo "  npm install -D typescript"
    echo "  or: yarn add -D typescript"
    echo ""
    echo "After installation, retry the commit."
    echo ""
    exit 1
  fi
  
  if ! command -v eslint &> /dev/null && ! command -v npx &> /dev/null; then
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "   ❌ ENVIRONMENT ERROR - COMMIT BLOCKED"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "Required tool 'eslint' is NOT installed."
    echo ""
    echo "Install commands:"
    echo "  npm install -D eslint"
    echo "  or use npx: npx eslint (will auto-install)"
    echo ""
    exit 1
  fi
  
  # Run TypeScript check
  npx tsc --noEmit 2>&1 | head -30
  TSC_EXIT=$?
  if [ "$TSC_EXIT" -ne 0 ]; then
    echo ""
    echo "❌ TYPE ERRORS. Commit blocked."
    echo "Fix the type errors above before committing."
    exit 1
  fi
  echo "✅ TypeScript check passed."
  
  # Run ESLint
  if [ -f ".eslintrc.json" ] || [ -f ".eslintrc.js" ] || [ -f "eslint.config.js" ]; then
    npx eslint "$CHANGED_FILES" --max-warnings=0 2>&1 | head -30
    ESLINT_EXIT=$?
    if [ "$ESLINT_EXIT" -ne 0 ]; then
      echo ""
      echo "❌ LINT ERRORS. Commit blocked."
      echo "Fix the lint errors above before committing."
      exit 1
    fi
    echo "✅ ESLint passed."
  fi

elif [ "$PROJECT_LANG" = "python" ]; then
  # Python: require Ruff (100x faster than Flake8) + optional mypy for type check
  if ! command -v ruff &> /dev/null; then
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "   ❌ ENVIRONMENT ERROR - COMMIT BLOCKED"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "Required tool 'ruff' is NOT installed."
    echo ""
    echo "Ruff is the fastest Python linter (100x faster than Flake8)."
    echo "It covers: syntax, complexity, duplicate code, style, imports."
    echo ""
    echo "Install commands:"
    echo "  pip install ruff"
    echo "  or: pipx install ruff"
    echo "  or: conda install -c conda-forge ruff"
    echo ""
    echo "After installation, retry the commit."
    echo ""
    exit 1
  fi
  
  # Run Ruff (includes syntax, lint, complexity checks)
  ruff check "$CHANGED_FILES" 2>&1 | head -30
  RUFF_EXIT=$?
  if [ "$RUFF_EXIT" -ne 0 ]; then
    echo ""
    echo "❌ RUFF ERRORS. Commit blocked."
    echo "Fix the lint errors above before committing."
    echo ""
    echo "Tip: Run 'ruff check --fix' to auto-fix some issues."
    exit 1
  fi
  echo "✅ Ruff lint check passed."
  
  # Optional: Type checking with mypy (if installed)
  if command -v mypy &> /dev/null; then
    mypy "$CHANGED_FILES" --ignore-missing-imports 2>&1 | head -30
    MYPY_EXIT=$?
    if [ "$MYPY_EXIT" -ne 0 ]; then
      echo ""
      echo "❌ TYPE ERRORS (mypy). Commit blocked."
      echo "Fix the type errors above before committing."
      exit 1
    fi
    echo "✅ mypy type check passed."
  fi

elif [ "$PROJECT_LANG" = "go" ]; then
  # Go: require golangci-lint
  if ! command -v golangci-lint &> /dev/null; then
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "   ❌ ENVIRONMENT ERROR - COMMIT BLOCKED"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "Required tool 'golangci-lint' is NOT installed."
    echo ""
    echo "golangci-lint is the fastest Go linter aggregator."
    echo "It includes: gofmt, govet, ineffassign, staticcheck, and more."
    echo ""
    echo "Install commands:"
    echo "  go install github.com/golangci/golangci-lint/cmd/golangci-lint@latest"
    echo "  or: curl -sSfL https://raw.githubusercontent.com/golangci/golangci-lint/master/install.sh | sh"
    echo ""
    exit 1
  fi
  
  golangci-lint run 2>&1 | head -30
  GO_LINT_EXIT=$?
  if [ "$GO_LINT_EXIT" -ne 0 ]; then
    echo ""
    echo "❌ LINT ERRORS (golangci-lint). Commit blocked."
    echo "Fix the lint errors above before committing."
    exit 1
  fi
  echo "✅ golangci-lint passed."

elif [ "$PROJECT_LANG" = "dart" ]; then
  # Dart: require dart analyze
  if ! command -v dart &> /dev/null; then
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "   ❌ ENVIRONMENT ERROR - COMMIT BLOCKED"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "Required tool 'dart' SDK is NOT installed."
    echo ""
    echo "Install commands:"
    echo "  macOS: brew install dart"
    echo "  Linux: sudo apt-get install dart"
    echo "  Windows: choco install dart-sdk"
    echo "  or: https://dart.dev/get-dart"
    echo ""
    exit 1
  fi
  
  dart analyze 2>&1 | head -30
  DART_ANALYZE_EXIT=$?
  if [ "$DART_ANALYZE_EXIT" -ne 0 ]; then
    echo ""
    echo "❌ DART ANALYZE ERRORS. Commit blocked."
    echo "Fix the analysis errors above before committing."
    exit 1
  fi
  echo "✅ dart analyze passed."

elif [ "$PROJECT_LANG" = "flutter" ]; then
  # Flutter: require flutter analyze
  if ! command -v flutter &> /dev/null; then
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "   ❌ ENVIRONMENT ERROR - COMMIT BLOCKED"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "Required tool 'flutter' SDK is NOT installed."
    echo ""
    echo "Install commands:"
    echo "  https://docs.flutter.dev/get-started/install"
    echo ""
    exit 1
  fi
  
  flutter analyze 2>&1 | head -30
  FLUTTER_ANALYZE_EXIT=$?
  if [ "$FLUTTER_ANALYZE_EXIT" -ne 0 ]; then
    echo ""
    echo "❌ FLUTTER ANALYZE ERRORS. Commit blocked."
    echo "Fix the analysis errors above before committing."
    exit 1
  fi
  echo "✅ flutter analyze passed."

elif [ "$PROJECT_LANG" = "cpp" ]; then
  # C++: PRIMARY - clang-tidy, SUPPLEMENTAL - cppcheck
  
  # PRIMARY: clang-tidy - blocks on errors
  if ! command -v clang-tidy &> /dev/null; then
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo "   ❌ ENVIRONMENT ERROR - COMMIT BLOCKED"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "Required tool 'clang-tidy' is NOT installed."
    echo ""
    echo "clang-tidy is the official C++ linter from LLVM."
    echo ""
    echo "Install commands:"
    echo "  macOS: brew install llvm"
    echo "  Ubuntu/Debian: sudo apt-get install clang-tidy"
    echo "  Fedora: sudo dnf install clang-tools-extra"
    echo ""
    exit 1
  fi
  
  echo "Running clang-tidy (PRIMARY C++ checker)..."
  
  # Get changed C++ files
  CPP_CHANGED_FILES=$(echo "$CHANGED_FILES" | grep -E '\.(cpp|cxx|cc|c|hpp|h)$' || true)
  if [ -n "$CPP_CHANGED_FILES" ]; then
    # Run clang-tidy with common checks
    clang-tidy $CPP_CHANGED_FILES -- \
      -std=c++17 \
      -Wall -Wextra \
      -I. -I./include \
      2>&1 | head -50
    
    CLANG_TIDY_EXIT=$?
    if [ "$CLANG_TIDY_EXIT" -ne 0 ]; then
      echo ""
      echo "❌ CLANG-TIDY ERRORS. Commit blocked."
      echo "Fix the issues above before committing."
      exit 1
    fi
    echo "✅ clang-tidy passed."
  fi
  
  # SUPPLEMENTAL: cppcheck - also blocks on errors
  if command -v cppcheck &> /dev/null; then
    echo "Running cppcheck (SUPPLEMENTAL C++ checker)..."
    
    CPP_CHANGED_FILES=$(echo "$CHANGED_FILES" | grep -E '\.(cpp|cxx|cc|c|hpp|h)$' || true)
    if [ -n "$CPP_CHANGED_FILES" ]; then
      cppcheck --enable=all \
        --error-exitcode=1 \
        --std=c++17 \
        --suppress=missingIncludeSystem \
        $CPP_CHANGED_FILES \
        2>&1 | head -30
      
      CPPCHECK_EXIT=$?
      if [ "$CPPCHECK_EXIT" -ne 0 ]; then
        echo ""
        echo "❌ CPPCHECK ERRORS. Commit blocked."
        echo "Fix the issues above before committing."
        exit 1
      fi
      echo "✅ cppcheck passed."
    fi
  else
    echo "ℹ️  cppcheck not installed. Skipping supplemental check."
    echo "   Install with: apt-get install cppcheck  (or brew install cppcheck)"
